# HTTP cache
data/cache/

# PDF downloads (large binaries, regenerable from metadata). Keep the extraction
# corpus ignored except for the manifest and five exact files used by Citation Receipts.
data/pdfs/*
!data/pdfs/manifest.json
!data/pdfs/en/
data/pdfs/en/*
!data/pdfs/en/56.pdf
!data/pdfs/en/265.pdf
!data/pdfs/en/574.pdf
!data/pdfs/en/709.pdf
!data/pdfs/en/777.pdf

# Corpus extraction bundles and coordinate sidecars are regenerated by
# `python -m corpus shadow-extract`. Keep the five repaired pilot artifacts for
# local compatibility/smoke tests; full-corpus outputs are uploaded immutably.
data/corpus/extractions/*
data/corpus/sidecars/*


# Logs
scraper.log

evals/results*.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment variables
.env
.env.*

# MCP config (contains API keys)
.mcp.json

